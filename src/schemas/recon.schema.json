{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cased.dev/schemas/recon.schema.json",
  "title": "Cased Recon",
  "description": "Structural model of a codebase gathered during the reconnaissance phase of an audit.",
  "type": "object",
  "required": ["meta", "structure"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["project", "commit", "timestamp", "scope"],
      "additionalProperties": false,
      "properties": {
        "project": {
          "type": "string",
          "description": "Project name (from Cargo.toml, package.json, etc.)"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "Full or abbreviated SHA of the audited commit"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the recon was performed (ISO 8601 with timezone)"
        },
        "scope": {
          "type": "string",
          "description": "What was included and excluded from this audit"
        }
      }
    },
    "structure": {
      "type": "object",
      "required": ["root", "total_files", "total_lines", "languages", "modules"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "Repository root path"
        },
        "total_files": { "type": "integer", "minimum": 0 },
        "total_lines": { "type": "integer", "minimum": 0 },
        "languages": {
          "type": "array",
          "description": "Detected languages with file and line counts",
          "items": {
            "type": "object",
            "required": ["language", "files", "lines", "percentage"],
            "additionalProperties": false,
            "properties": {
              "language": { "type": "string" },
              "files": { "type": "integer", "minimum": 0 },
              "lines": { "type": "integer", "minimum": 0 },
              "percentage": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "modules": {
          "type": "array",
          "description": "Logical modules or components identified in the codebase",
          "items": {
            "type": "object",
            "required": ["name", "path", "files", "lines"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Module identifier (e.g., 'auth', 'api', 'db')"
              },
              "path": {
                "type": "string",
                "description": "Root path of the module (file or directory)"
              },
              "files": { "type": "integer", "minimum": 0 },
              "lines": { "type": "integer", "minimum": 0 },
              "entry_points": {
                "type": "array",
                "description": "Public API surface of this module",
                "items": {
                  "type": "object",
                  "required": ["name", "path", "line", "kind"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "path": { "type": "string" },
                    "line": { "type": "integer", "minimum": 1 },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "http_handler",
                        "cli_command",
                        "cli_main",
                        "public_fn",
                        "exported_symbol",
                        "main",
                        "event_handler",
                        "library_pipeline",
                        "library_validation"
                      ]
                    }
                  }
                }
              },
              "dependencies": {
                "type": "array",
                "description": "Internal module dependencies (imports from other modules in this project)",
                "items": {
                  "type": "object",
                  "required": ["target", "weight"],
                  "additionalProperties": false,
                  "properties": {
                    "target": {
                      "type": "string",
                      "description": "Name of the module this imports from"
                    },
                    "weight": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Number of import sites"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "External (third-party) dependencies declared in the project manifest",
      "required": ["manifest", "items"],
      "additionalProperties": false,
      "properties": {
        "manifest": {
          "type": "string",
          "description": "Path to manifest file (Cargo.toml, package.json, etc.)"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version", "kind"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "kind": {
                "type": "string",
                "enum": ["direct", "dev", "build", "optional", "workspace"]
              },
              "latest_version": {
                "type": "string",
                "description": "Latest version available upstream (if discoverable without network)"
              },
              "age_days": {
                "type": "integer",
                "minimum": 0,
                "description": "Days since this version was published"
              },
              "notes": {
                "type": "string",
                "description": "Any flags: yanked, deprecated, advisory, etc."
              }
            }
          }
        }
      }
    },
    "churn": {
      "type": "object",
      "description": "Git history analysis over the audit window",
      "required": ["period", "hotspots"],
      "additionalProperties": false,
      "properties": {
        "period": {
          "type": "string",
          "description": "Human-readable window, e.g. 'last 12 months'"
        },
        "hotspots": {
          "type": "array",
          "description": "Files ranked by commit frequency",
          "items": {
            "type": "object",
            "required": ["path", "commits", "authors", "last_touched", "monthly_commits"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "commits": { "type": "integer", "minimum": 0 },
              "authors": { "type": "integer", "minimum": 0 },
              "last_touched": { "type": "string", "format": "date" },
              "monthly_commits": {
                "type": "array",
                "description": "Twelve integers, oldest first, most recent last. Used for sparkline rendering.",
                "items": { "type": "integer", "minimum": 0 },
                "minItems": 12,
                "maxItems": 12
              }
            }
          }
        },
        "recent_activity": {
          "type": "object",
          "description": "Last 30 days summary",
          "required": ["total_commits", "active_authors", "files_changed"],
          "additionalProperties": false,
          "properties": {
            "total_commits": { "type": "integer", "minimum": 0 },
            "active_authors": { "type": "integer", "minimum": 0 },
            "files_changed": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "testing": {
      "type": "object",
      "description": "Project's canonical test tooling, detected deterministically from config files. Agents should consult this before running any tests — the wrong runner (e.g., plain `cargo test` against a nextest-configured project) can produce false failures that look like real findings.",
      "required": ["runner", "command"],
      "additionalProperties": false,
      "properties": {
        "runner": {
          "type": "string",
          "enum": ["nextest", "cargo-test", "just", "npm", "custom", "unknown"],
          "description": "Label for the test harness or wrapper. Inferred from the command string."
        },
        "command": {
          "type": "string",
          "description": "The canonical shell command to run the project's test suite. Empty string when runner is 'unknown'."
        },
        "sources": {
          "type": "array",
          "description": "File paths (relative to project root) that informed the detection.",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "string",
          "description": "Warnings about test tooling peculiarities — emitted only when something non-obvious applies (e.g., nextest process isolation caveats)."
        }
      }
    },
    "boundaries": {
      "type": "array",
      "description": "Trust, security, or architectural boundaries identified in the codebase. Judgment-driven.",
      "items": {
        "type": "object",
        "required": ["name", "description", "modules"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Short identifier, e.g. 'shell_execution' or 'external_input'"
          },
          "description": { "type": "string" },
          "modules": {
            "type": "array",
            "description": "Which modules sit on this boundary",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
